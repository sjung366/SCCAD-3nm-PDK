SITE core
  CLASS CORE ;
  SIZE 0.042 BY 0.144 ;
END core

MACRO AND2x1
  CLASS CORE ;
  FOREIGN AND2x1 ;
  ORIGIN 0 0 ;
  SIZE 0.21 BY 0.144 ;
  SYMMETRY X Y ;
  SITE core ;
  PIN A
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER M1 ;
        RECT 0.015 0.018 0.027 0.102 ;
    END
  END A
  PIN B
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER M1 ;
        RECT 0.099 0.042 0.111 0.102 ;
    END
  END B
  PIN Y
    DIRECTION OUTPUT ;
    USE SIGNAL ;
    PORT
      LAYER M1 ;
        RECT 0.183 0.018 0.195 0.102 ;
    END
  END Y
  PIN VDD
    DIRECTION INOUT ;
    USE POWER ;
    PORT
      LAYER M1 ;
        RECT -0.009 0.114 0.219 0.126 ;
    END
  END VDD
  PIN VSS
    DIRECTION INOUT ;
    USE GROUND ;
    PORT
      LAYER M1 ;
        RECT -0.009 -0.006 0.219 0.006 ;
    END
  END VSS
  OBS
    LAYER M1 ;
      POLYGON 0.069 0.096 0.069 0.03 0.141 0.03 0.141 0.066 0.153 0.066 0.153 0.018 0.057 0.018 0.057 0.096 ;
  END
END AND2x1

