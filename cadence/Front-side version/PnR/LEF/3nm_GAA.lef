VIA Pad_M9
  LAYER M9 ;
    RECT -0.016 -0.025 0.016 0.025 ;
  LAYER V9 ;
    RECT -0.016 -0.016 0.016 0.016 ;
  LAYER Pad ;
    RECT -0.027 -0.016 0.027 0.016 ;
END Pad_M9

VIA M9_M8
